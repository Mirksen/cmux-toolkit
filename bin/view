#!/usr/bin/env bash
# view / viewtab — Open files rendered in cmux browser
# Usage: view <file>      → opens in new pane (split)
#        viewtab <file>   → opens as tab in same pane
# Supports: .md (rendered HTML), .pdf (native), .html (native), images, code files
#
# Diff highlighting: set VIEW_DIFF_FILE to a temp file containing the new_string.
# Changed lines will be highlighted in green with auto-scroll.
# Surface reuse: set VIEW_REUSE_SURFACE to navigate an existing tab instead of creating new.

set -euo pipefail

# Detect mode: "view" = new split pane, "viewtab" = reuse existing tab
CMD_NAME=$(basename "$0")
MODE="split"
[[ "$CMD_NAME" == "viewtab" ]] && MODE="tab"

FILE="${1:-}"
[[ -z "$FILE" ]] && echo "Usage: $CMD_NAME <file>" && exit 1

# Resolve relative to cwd
[[ "$FILE" != /* ]] && FILE="$(pwd)/$FILE"
[[ ! -f "$FILE" ]] && echo "File not found: $FILE" && exit 1

EXT="${FILE##*.}"
BASENAME=$(basename "$FILE" ".$EXT")
DIFF_FILE="${VIEW_DIFF_FILE:-}"

# --- CSS shared across all rendered views ---
read -r -d '' CSS << 'ENDCSS' || true
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; line-height: 1.6; color: #1d1d1f; background: #fff; }
table { border-collapse: collapse; width: 100%; margin: 1rem 0; font-size: 0.95em; }
th, td { border: 1px solid #d2d2d7; padding: 0.5rem 0.75rem; text-align: left; }
th { background: #f5f5f7; font-weight: 600; }
tr:hover { background: #fafafa; }
code { background: #f5f5f7; padding: 0.15rem 0.4rem; border-radius: 3px; font-size: 0.9em; }
pre { background: #f5f5f7; padding: 1rem; border-radius: 6px; overflow-x: auto; font-size: 0.85em; }
pre code { background: none; padding: 0; }
h1 { border-bottom: 1px solid #d2d2d7; padding-bottom: 0.5rem; }
h2 { margin-top: 2rem; }
h3 { margin-top: 1.5rem; }
a { color: #0066cc; text-decoration: none; }
a:hover { text-decoration: underline; }
blockquote { border-left: 3px solid #d2d2d7; margin: 1rem 0; padding: 0.5rem 1rem; color: #6e6e73; }
hr { border: none; border-top: 1px solid #d2d2d7; margin: 2rem 0; }
input[type="checkbox"] { margin-right: 0.4rem; }
del { color: #86868b; }
li { margin: 0.25rem 0; }
.diff-new { background: #d4edda; border-left: 3px solid #28a745; padding-left: 0.5rem; margin-left: -0.5rem; padding-right: 0.5rem; }
ENDCSS

SCROLL_SCRIPT='<script>document.querySelector(".diff-new")?.scrollIntoView({block:"center",behavior:"smooth"})</script>'

# --- Build the URL to open ---
URL=""
OUT="/tmp/view-${BASENAME}.html"

case "$EXT" in
  md)
    # Strip YAML frontmatter (between --- markers)
    if head -1 "$FILE" | grep -q '^---$'; then
      CONTENT=$(awk 'BEGIN{fm=0} /^---$/{fm++; next} fm>=2{print}' "$FILE")
    else
      CONTENT=$(cat "$FILE")
    fi

    # Apply diff markers if available
    if [[ -n "$DIFF_FILE" && -f "$DIFF_FILE" ]]; then
      CONTENT=$(python3 -c "
import sys
content = sys.stdin.read()
with open(sys.argv[1], 'r') as f:
    new_str = f.read().rstrip('\n')
if not new_str or new_str not in content:
    print(content, end='')
else:
    result = content.replace(new_str, '<div class=\"diff-new\">\n\n' + new_str + '\n\n</div>', 1)
    print(result, end='')
" "$DIFF_FILE" <<< "$CONTENT")
    fi

    {
      echo "<!DOCTYPE html><html><head><meta charset=\"utf-8\">"
      echo "<style>${CSS}</style>"
      echo "<title>${BASENAME}</title></head><body>"
      echo "$CONTENT" | NODE_PATH="$(npm root -g 2>/dev/null)" node -e "const{marked}=require('marked');marked.setOptions({gfm:true});let md='';process.stdin.on('data',d=>md+=d);process.stdin.on('end',()=>process.stdout.write(marked.parse(md)))" 2>/dev/null || echo "$CONTENT"
      echo "$SCROLL_SCRIPT"
      echo "</body></html>"
    } > "$OUT"
    URL="file://$OUT"
    ;;

  pdf|html|htm|png|jpg|jpeg|gif|svg|webp)
    URL="file://${FILE}"
    ;;

  *)
    # Code files: syntax-highlighted via Prism.js
    LANG_CLASS="language-${EXT}"
    case "$EXT" in
      py) LANG_CLASS="language-python" ;;
      sh|bash|zsh) LANG_CLASS="language-bash" ;;
      js) LANG_CLASS="language-javascript" ;;
      ts) LANG_CLASS="language-typescript" ;;
      yml|yaml) LANG_CLASS="language-yaml" ;;
    esac

    # Build code HTML with optional diff highlighting
    CODE_HTML=$(python3 -c "
import html, sys, os

file_path = sys.argv[1]
diff_path = sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else ''

with open(file_path, 'r') as f:
    lines = f.readlines()

highlight_lines = set()
if diff_path and os.path.isfile(diff_path):
    with open(diff_path, 'r') as f:
        new_str = f.read().rstrip('\n')
    if new_str:
        new_lines = new_str.split('\n')
        file_stripped = [l.rstrip('\n') for l in lines]
        for i in range(len(file_stripped) - len(new_lines) + 1):
            if file_stripped[i:i+len(new_lines)] == new_lines:
                highlight_lines = set(range(i+1, i+1+len(new_lines)))
                break

for i, line in enumerate(lines, 1):
    escaped = html.escape(line.rstrip('\n'))
    if i in highlight_lines:
        print(f'<span class=\"diff-new\">{escaped}</span>')
    else:
        print(escaped)
" "$FILE" "$DIFF_FILE")

    {
      echo "<!DOCTYPE html><html><head><meta charset=\"utf-8\">"
      echo "<link href=\"https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css\" rel=\"stylesheet\" />"
      echo "<style>${CSS} pre .diff-new { display: block; background: #d4edda; border-left: 3px solid #28a745; margin: 0 -1rem; padding: 0 1rem; }</style>"
      echo "<title>${BASENAME}.${EXT}</title></head><body>"
      echo "<h1>${BASENAME}.${EXT}</h1>"
      if [[ -n "$DIFF_FILE" && -f "$DIFF_FILE" ]]; then
        # Pre-formatted with diff spans — skip Prism auto-highlight
        echo "<pre><code>${CODE_HTML}</code></pre>"
      else
        echo "<pre><code class=\"${LANG_CLASS}\">${CODE_HTML}</code></pre>"
        echo "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js\"></script>"
        echo "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-python.min.js\"></script>"
        echo "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-bash.min.js\"></script>"
        echo "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-json.min.js\"></script>"
        echo "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-yaml.min.js\"></script>"
        echo "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-typescript.min.js\"></script>"
        echo "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-toml.min.js\"></script>"
      fi
      echo "$SCROLL_SCRIPT"
      echo "</body></html>"
    } > "$OUT"
    URL="file://$OUT"
    ;;
esac

# Append source path as URL fragment (visible in address bar, no effect on rendering)
[[ -n "$URL" && "$URL" == file:///tmp/* ]] && URL="${URL}#source=${FILE}"

# --- Open based on mode ---
REUSE_SURFACE="${VIEW_REUSE_SURFACE:-}"

if [[ "$MODE" == "tab" ]]; then
  # Try to reuse an existing browser surface (navigate instead of creating new tab)
  if [[ -n "$REUSE_SURFACE" ]]; then
    if cmux browser --surface "$REUSE_SURFACE" navigate "$URL" 2>/dev/null; then
      # Navigated existing tab — no focus change, no flash
      echo "OK $REUSE_SURFACE"
    else
      # Surface gone — fall through to create a new one
      REUSE_SURFACE=""
    fi
  fi

  if [[ -z "$REUSE_SURFACE" ]]; then
    # Use cmux identify to reliably get our pane and surface
    IDENT=$(cmux identify 2>/dev/null || true)
    OUR_PANE=$(echo "$IDENT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('caller',{}).get('pane_ref',''))" 2>/dev/null || true)
    OUR_SURFACE=$(echo "$IDENT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('caller',{}).get('surface_ref',''))" 2>/dev/null || true)
    if [[ -n "$OUR_PANE" ]]; then
      cmux new-surface --type browser --pane "$OUR_PANE" --url "$URL"
      # Refocus the original terminal tab to minimise browser flash
      [[ -n "$OUR_SURFACE" ]] && cmux move-surface --surface "$OUR_SURFACE" --focus true 2>/dev/null
    else
      cmux browser new "$URL"
    fi
  fi
else
  cmux browser new "$URL"
fi

echo "Opened: ${BASENAME}.${EXT}"
